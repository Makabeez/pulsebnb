# =========================================================
#  PulseBNB - Environment configuration
# =========================================================

# Etherscan V2 unified key - same key works for BNB Chain (chainid=56)
# Get free at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# BNB Chain mainnet RPC - default public (rate limited, OK for hackathon)
# Faster options: https://rpc.ankr.com/bsc, https://bsc-dataseed.binance.org
BSC_RPC=https://bsc-dataseed.binance.org

# SQLite DB path
DB_PATH=./data/pulsebnb.db

# Indexer poll interval (BNB block time = 3s, 60s leaves a safe gap)
POLL_INTERVAL_SEC=60

# How far back to seed on first run (300 blocks ~15 min on BNB)
LOOKBACK_BLOCKS=300

# ---- AI classifier (uses Joe's existing LiteLLM router on port 4000) ----
LITELLM_URL=http://127.0.0.1:4000
LITELLM_MODEL=enrichment
LITELLM_API_KEY=

# ---- Watchlist contract (deployed day 5-6) ----
WATCHLIST_CONTRACT=
DEPLOYER_PRIVATE_KEY=
