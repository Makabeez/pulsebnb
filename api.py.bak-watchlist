def hot(limit: int = Query(20, ge=1, le=100)):
    cutoff = int(time.time()) - 7 * 86400
    conn = db()
    rows = conn.execute(
        """SELECT c.*, d.spaceid, d.farcaster_username, d.farcaster_fid, d.farcaster_pfp
           FROM contracts c
