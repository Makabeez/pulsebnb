"""
PulseBNB - Read API (day 2)

Adds:
  GET /best         - AI-flagged 'real' contracts, sorted by ai_score
  GET /dashboard    - one-shot aggregate stats for the demo headline numbers
"""

import os
import math
import sqlite3
import time
from fastapi import FastAPI, Query
from fastapi.middleware.cors import CORSMiddleware
from dotenv import load_dotenv

load_dotenv()

DB_PATH = os.getenv("DB_PATH", "./data/pulsebnb.db")
WATCHLIST_CONTRACT = os.getenv("WATCHLIST_CONTRACT", "")

app = FastAPI(title="PulseBNB API", version="0.2")

app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_methods=["*"],
    allow_headers=["*"],
)


def db():
    conn = sqlite3.connect(DB_PATH)
    conn.row_factory = sqlite3.Row
    return conn


def deployer_dict(row):
    return {
        "address": row["address"],
        "spaceid": row["spaceid"],
        "farcaster_username": row["farcaster_username"],
        "farcaster_fid": row["farcaster_fid"],
        "farcaster_pfp": row["farcaster_pfp"],
    }


def contract_dict(r):
    return {
        "address": r["address"],
        "deployer": {
            "address": r["deployer"],
            "spaceid": r["spaceid"],
            "farcaster_username": r["farcaster_username"],
            "farcaster_fid": r["farcaster_fid"],
            "farcaster_pfp": r["farcaster_pfp"],
        },
        "block_number": r["block_number"],
        "tx_hash": r["tx_hash"],
        "deployed_at": r["deployed_at"],
        "contract_type": r["contract_type"],
        "verified": bool(r["verified"]),
        "contract_name": r["contract_name"],
        "tx_count": r["tx_count"],
        "ai_label": r["ai_label"],
        "ai_reason": r["ai_reason"],
        "ai_score": r["ai_score"],
    }


@app.get("/")
def root():
    return {
        "name": "PulseBNB API",
        "docs": "/docs",
        "endpoints": ["/dashboard", "/best", "/feed", "/leaderboard", "/hot", "/builder/{address}", "/stats"],
        "frontend": "https://pulsebnb-web.vercel.app",
    }


@app.get("/health")
def health():
    return {"ok": True, "chain": "bnb", "ts": int(time.time())}


@app.get("/feed")
def feed(
    limit: int = Query(50, ge=1, le=200),
    label: str = Query(None, description="Filter by ai_label: real|noise"),
):
    conn = db()
    if label:
        rows = conn.execute(
            """SELECT c.*, d.spaceid, d.farcaster_username, d.farcaster_fid, d.farcaster_pfp
               FROM contracts c
               LEFT JOIN deployers d ON d.address = c.deployer
               WHERE c.ai_label = ?
               ORDER BY c.deployed_at DESC LIMIT ?""",
            (label, limit),
        ).fetchall()
    else:
        rows = conn.execute(
            """SELECT c.*, d.spaceid, d.farcaster_username, d.farcaster_fid, d.farcaster_pfp
               FROM contracts c
               LEFT JOIN deployers d ON d.address = c.deployer
               ORDER BY c.deployed_at DESC LIMIT ?""",
            (limit,),
        ).fetchall()
    conn.close()
    return {"items": [contract_dict(r) for r in rows]}


@app.get("/best")
def best(
    limit: int = Query(20, ge=1, le=100),
    window: str = Query("7d", description="1d|7d|30d|all"),
    min_score: int = Query(60, ge=0, le=100),
):
    """The AI-curated headline view: only 'real' contracts above a confidence threshold."""
    days = {"1d": 1, "7d": 7, "30d": 30, "all": 36500}.get(window, 7)
    cutoff = int(time.time()) - days * 86400
    conn = db()
    rows = conn.execute(
        """SELECT c.*, d.spaceid, d.farcaster_username, d.farcaster_fid, d.farcaster_pfp
           FROM contracts c
           LEFT JOIN deployers d ON d.address = c.deployer
           WHERE c.ai_label = 'real'
             AND c.ai_score >= ?
             AND c.deployed_at >= ?
           ORDER BY c.ai_score DESC, c.deployed_at DESC
           LIMIT ?""",
        (min_score, cutoff, limit),
    ).fetchall()
    conn.close()
    return {
        "window": window,
        "min_score": min_score,
        "items": [contract_dict(r) for r in rows],
    }


@app.get("/leaderboard")
def leaderboard(window: str = "7d", limit: int = Query(50, ge=1, le=200)):
    """Top builders ranked by transparent score."""
    days = {"1d": 1, "7d": 7, "30d": 30, "all": 36500}.get(window, 7)
    cutoff = int(time.time()) - days * 86400

    conn = db()
    rows = conn.execute(
        """SELECT c.deployer,
                  COUNT(*) AS n_contracts,
                  SUM(c.verified) AS n_verified,
                  SUM(c.tx_count) AS total_tx,
                  SUM(CASE WHEN c.ai_label='real' THEN 1 ELSE 0 END) AS n_real,
                  MAX(c.deployed_at) AS last_deploy,
                  d.spaceid, d.farcaster_username, d.farcaster_fid, d.farcaster_pfp
           FROM contracts c
           LEFT JOIN deployers d ON d.address = c.deployer
           WHERE c.deployed_at >= ?
           GROUP BY c.deployer
           ORDER BY n_real DESC, n_contracts DESC, total_tx DESC
           LIMIT ?""",
        (cutoff, limit),
    ).fetchall()
    conn.close()

    items = []
    for r in rows:
        n = r["n_contracts"] or 0
        v = r["n_verified"] or 0
        real = r["n_real"] or 0
        tx = r["total_tx"] or 0
        verified_ratio = (v / n) if n else 0
        # New scoring: real count gets a big weight (it's the differentiator)
        score = round(
            0.5 * real + 0.2 * n + 0.2 * math.log1p(tx) + 0.1 * (verified_ratio * 10),
            2,
        )
        items.append({
            "address": r["deployer"],
            "spaceid": r["spaceid"],
            "farcaster_username": r["farcaster_username"],
            "farcaster_fid": r["farcaster_fid"],
            "farcaster_pfp": r["farcaster_pfp"],
            "n_contracts": n,
            "n_real": real,
            "n_verified": v,
            "total_tx": tx,
            "verified_ratio": round(verified_ratio, 3),
            "last_deploy": r["last_deploy"],
            "score": score,
        })
    items.sort(key=lambda x: x["score"], reverse=True)
    return {"window": window, "items": items}


