"""
PulseBNB AI Classifier - production implementation.

Routes each contract through Cerebras gpt-oss-120b via LiteLLM 'enrichment' alias.
Returns binary label (real | noise) + 0-100 confidence score + 1-line reason.

Token budget per call: ~100 input + ~80 output = ~180 tokens.
At ~2,200 contracts/day this is ~400K tokens/day, well under Cerebras 1M/day free tier.
Bottleneck is actually 30 RPM rate limit -> indexer paces 1 call every 2s.
"""

import os
import json
import logging
import time
import httpx

log = logging.getLogger("pulsebnb.ai")

LITELLM_URL = os.getenv("LITELLM_URL", "http://127.0.0.1:4000")
LITELLM_MODEL = os.getenv("LITELLM_MODEL", "enrichment")
LITELLM_API_KEY = os.getenv("LITELLM_API_KEY", "")

# Single shared HTTP client - connection pooling
_client = httpx.Client(timeout=30.0)

# Tight system prompt - every token costs us
SYSTEM_PROMPT = (
    "You classify newly-deployed BNB Chain smart contracts as either REAL "
    "(legitimate builder project worth tracking) or NOISE (fork, honeypot, "
    "meme template, copy-paste scam, dead code). Reply with ONLY a JSON object "
    'of shape {"label":"real"|"noise","score":0-100,"reason":"<=12 words"}. '
    "Score is your confidence the label is correct."
)


def _build_user_msg(contract: dict) -> str:
    """Compact contract description, ~50 tokens."""
    parts = [
        f"type={contract.get('contract_type') or 'UNKNOWN'}",
        f"verified={'yes' if contract.get('verified') else 'no'}",
    ]
    name = contract.get("contract_name")
    if name:
        parts.append(f"name={name[:40]}")
    return "Classify: " + ", ".join(parts)


def _parse_response(text: str):
    """Extract JSON from model output. gpt-oss-120b sometimes wraps in markdown."""
    if not text:
        return None
    text = text.strip()
    # Strip common code-fence wrappers
    if text.startswith("```"):
        lines = text.split("\n")
        text = "\n".join(lines[1:-1]) if len(lines) > 2 else text.strip("`")
        text = text.strip()
    # Try direct parse
    try:
        return json.loads(text)
    except json.JSONDecodeError:
        pass
    # Try to find first {...} block
    start = text.find("{")
    end = text.rfind("}")
    if start >= 0 and end > start:
        try:
            return json.loads(text[start : end + 1])
        except json.JSONDecodeError:
            return None
    return None


def classify_with_ai(contract: dict):
    """
    Returns (label, reason, score):
      label  : 'real' | 'noise' | None  (None means transient error, will retry)
      reason : str | None
      score  : int 0-100
    """
    if not LITELLM_API_KEY:
        log.warning("LITELLM_API_KEY not set, skipping AI classification")
        return (None, None, 0)

    payload = {
        "model": LITELLM_MODEL,
        "messages": [
            {"role": "system", "content": SYSTEM_PROMPT},
            {"role": "user", "content": _build_user_msg(contract)},
        ],
        # gpt-oss-120b is a reasoning model - needs headroom for internal reasoning
        # before producing the JSON answer. 200 tokens = ~120 reasoning + 80 output.
        "max_tokens": 200,
        "temperature": 0.0,  # deterministic classifier
    }
    headers = {
        "Authorization": f"Bearer {LITELLM_API_KEY}",
        "Content-Type": "application/json",
    }

    try:
        r = _client.post(
            f"{LITELLM_URL}/v1/chat/completions",
            json=payload,
            headers=headers,
        )
        r.raise_for_status()
        data = r.json()
    except httpx.HTTPStatusError as e:
        status = e.response.status_code
        if status == 429:
            # Rate limit - back off, will retry on next tick
            log.warning("ai 429 rate-limited for %s", contract.get("address", "?")[:10])
            time.sleep(2)
        else:
            log.warning("ai %s HTTP %d: %s", contract.get("address", "?")[:10],
                        status, e.response.text[:200])
        return (None, None, 0)
    except Exception as e:
        log.warning("ai call failed for %s: %s", contract.get("address", "?")[:10], e)
        return (None, None, 0)

    try:
        content = data["choices"][0]["message"]["content"]
    except (KeyError, IndexError, TypeError):
        log.warning("ai unexpected response shape: %s", str(data)[:200])
        return (None, None, 0)

    parsed = _parse_response(content)
    if not parsed or "label" not in parsed:
        log.warning("ai unparseable output for %s: %r",
                    contract.get("address", "?")[:10], content[:120])
        return (None, None, 0)

    label = str(parsed.get("label", "")).lower().strip()
    if label not in ("real", "noise"):
        # Snap to nearest valid label
        if any(w in label for w in ("real", "legit", "good", "valid")):
            label = "real"
        else:
            label = "noise"

    reason = str(parsed.get("reason", ""))[:200]
    score = parsed.get("score", 0)
    try:
        score = max(0, min(100, int(score)))
    except (ValueError, TypeError):
        score = 50

    return (label, reason, score)
