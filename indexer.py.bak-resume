"""
PulseBNB - Indexer (day 2)

Same architecture as day 1 + real AI classification + Space ID + Farcaster bulk.

Cerebras rate-limit awareness:
  - Free tier = 30 RPM = 1 call every 2s minimum
  - We classify in small batches every 2 min (10 calls per batch) which keeps us
    well under 30 RPM and gives the indexer breathing room.
"""

import os
import time
import sqlite3
import logging
import requests
from apscheduler.schedulers.blocking import BlockingScheduler
from dotenv import load_dotenv

from ai_classifier import classify_with_ai
from spaceid_resolver import resolve_spaceid
from farcaster_resolver import resolve_farcaster_bulk

load_dotenv()

# -------- Config --------
ETHERSCAN_API_KEY = os.getenv("ETHERSCAN_API_KEY", "")
BSC_RPC = os.getenv("BSC_RPC", "https://bsc-dataseed.binance.org")
DB_PATH = os.getenv("DB_PATH", "./data/pulsebnb.db")
POLL_INTERVAL_SEC = int(os.getenv("POLL_INTERVAL_SEC", "60"))
LOOKBACK_BLOCKS = int(os.getenv("LOOKBACK_BLOCKS", "300"))

ETHERSCAN_V2 = "https://api.etherscan.io/v2/api"
BSC_CHAIN_ID = 56

SELECTORS = {
    "ERC20":   ["18160ddd", "a9059cbb", "70a08231"],
    "ERC721":  ["6352211e", "70a08231", "23b872dd"],
    "ERC1155": ["f242432a", "00fdd58e", "2eb2c2d6"],
}

# -------- Logging --------
logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s [%(levelname)s] %(message)s",
    handlers=[
        logging.FileHandler("logs/indexer.log"),
        logging.StreamHandler(),
    ],
)
log = logging.getLogger("pulsebnb")


# -------- DB Schema --------
def init_db():
    conn = sqlite3.connect(DB_PATH)
    c = conn.cursor()
    c.executescript("""
    CREATE TABLE IF NOT EXISTS contracts (
        address TEXT PRIMARY KEY,
        deployer TEXT NOT NULL,
        block_number INTEGER NOT NULL,
        tx_hash TEXT NOT NULL,
        deployed_at INTEGER NOT NULL,
        contract_type TEXT,
        verified INTEGER DEFAULT 0,
        contract_name TEXT,
        tx_count INTEGER DEFAULT 0,
        last_tx_count_update INTEGER DEFAULT 0,
        ai_label TEXT,
        ai_reason TEXT,
        ai_score INTEGER DEFAULT 0,
        ai_classified_at INTEGER DEFAULT 0
    );
    CREATE INDEX IF NOT EXISTS idx_deployer ON contracts(deployer);
    CREATE INDEX IF NOT EXISTS idx_deployed_at ON contracts(deployed_at);
    CREATE INDEX IF NOT EXISTS idx_block ON contracts(block_number);
    CREATE INDEX IF NOT EXISTS idx_ai_label ON contracts(ai_label);
    CREATE INDEX IF NOT EXISTS idx_ai_score ON contracts(ai_score);

    CREATE TABLE IF NOT EXISTS deployers (
        address TEXT PRIMARY KEY,
        spaceid TEXT,
        farcaster_username TEXT,
        farcaster_fid INTEGER,
        farcaster_pfp TEXT,
        last_resolved INTEGER DEFAULT 0
    );

    CREATE TABLE IF NOT EXISTS meta (
        key TEXT PRIMARY KEY,
        value TEXT
    );
    """)
    # Enable WAL for concurrent reader/writer
    c.execute("PRAGMA journal_mode=WAL;")
    conn.commit()
    conn.close()
    log.info("DB initialized at %s (WAL on)", DB_PATH)


def db():
    conn = sqlite3.connect(DB_PATH, timeout=30.0)
    conn.row_factory = sqlite3.Row
    conn.execute("PRAGMA busy_timeout=10000")
    return conn


# -------- RPC helpers --------
def rpc_call(method, params):
    payload = {"jsonrpc": "2.0", "id": 1, "method": method, "params": params}
    try:
        r = requests.post(BSC_RPC, json=payload, timeout=10)
        r.raise_for_status()
        return r.json().get("result")
    except Exception as e:
        log.warning("RPC %s failed: %s", method, e)
        return None


def get_latest_block():
    res = rpc_call("eth_blockNumber", [])
    return int(res, 16) if res else None


def get_block_with_txs(block_num):
    return rpc_call("eth_getBlockByNumber", [hex(block_num), True])


def get_tx_receipt(tx_hash):
    return rpc_call("eth_getTransactionReceipt", [tx_hash])


def get_code(address):
    return rpc_call("eth_getCode", [address, "latest"])


def classify_bytecode(bytecode):
    if not bytecode or bytecode == "0x":
        return "EMPTY"
    code = bytecode.lower()
    scores = {std: sum(1 for s in sels if s in code) for std, sels in SELECTORS.items()}
    best = max(scores, key=scores.get)
    if scores[best] >= 2:
        return best
    return "OTHER"


# -------- Indexing --------
def get_last_indexed_block():
    conn = db()
    row = conn.execute("SELECT value FROM meta WHERE key='last_block'").fetchone()
    conn.close()
    return int(row["value"]) if row else None


def set_last_indexed_block(block_num):
    conn = db()
    conn.execute(
        "INSERT INTO meta(key,value) VALUES('last_block',?) "
        "ON CONFLICT(key) DO UPDATE SET value=excluded.value",
        (str(block_num),),
    )
    conn.commit()
    conn.close()


def index_block(block_num):
    block = get_block_with_txs(block_num)
    if not block:
        return 0

    txs = block.get("transactions", [])
    block_ts = int(block.get("timestamp", "0x0"), 16)
    new_contracts = 0

    conn = db()
    for tx in txs:
        if tx.get("to") is not None:
            continue
        tx_hash = tx["hash"]
        receipt = get_tx_receipt(tx_hash)
        if not receipt:
            continue
        contract_addr = receipt.get("contractAddress")
        if not contract_addr:
            continue
        if receipt.get("status") != "0x1":
            continue

        deployer = tx["from"].lower()
        contract_addr = contract_addr.lower()
        code = get_code(contract_addr)
        ctype = classify_bytecode(code)

        try:
            conn.execute(
                """INSERT OR IGNORE INTO contracts
                   (address, deployer, block_number, tx_hash, deployed_at, contract_type)
                   VALUES (?, ?, ?, ?, ?, ?)""",
                (contract_addr, deployer, block_num, tx_hash, block_ts, ctype),
            )
            conn.execute(
                "INSERT OR IGNORE INTO deployers(address) VALUES(?)",
                (deployer,),
            )
            new_contracts += 1
            log.info("  + %s (%s) by %s", contract_addr[:10], ctype, deployer[:10])
        except Exception as e:
            log.error("DB insert failed: %s", e)

    conn.commit()
    conn.close()
    return new_contracts


def index_tick():
    latest = get_latest_block()
    if not latest:
        log.warning("Could not fetch latest block")
        return

    last_indexed = get_last_indexed_block()
    if last_indexed is None:
        last_indexed = latest - LOOKBACK_BLOCKS
        log.info("First run, starting at block %d", last_indexed)

    end_block = min(latest, last_indexed + 200)
    if end_block <= last_indexed:
        return

    log.info("Indexing blocks %d -> %d (%d blocks)",
             last_indexed + 1, end_block, end_block - last_indexed)
    total_new = 0
    for bn in range(last_indexed + 1, end_block + 1):
        total_new += index_block(bn)
        set_last_indexed_block(bn)

    if total_new:
        log.info("Tick: %d new contracts", total_new)


# -------- Verification status --------
def update_verification_batch():
    if not ETHERSCAN_API_KEY:
        return
    conn = db()
    rows = conn.execute(
        """SELECT address FROM contracts
           WHERE verified = 0
           ORDER BY deployed_at DESC LIMIT 20"""
    ).fetchall()

    for row in rows:
        addr = row["address"]
        try:
            r = requests.get(
                ETHERSCAN_V2,
                params={
                    "chainid": BSC_CHAIN_ID,
                    "module": "contract",
                    "action": "getsourcecode",
                    "address": addr,
                    "apikey": ETHERSCAN_API_KEY,
                },
                timeout=10,
            )
            data = r.json()
            if data.get("status") == "1" and data.get("result"):
                src = data["result"][0]
                source = src.get("SourceCode", "")
                name = src.get("ContractName", "")
                if source:
                    conn.execute(
                        "UPDATE contracts SET verified=1, contract_name=? WHERE address=?",
                        (name, addr),
                    )
                    log.info("  ✓ verified %s -> %s", addr[:10], name)
            time.sleep(0.25)
        except Exception as e:
            log.warning("Verify check failed for %s: %s", addr, e)
    conn.commit()
    conn.close()


# -------- Identity resolution (Space ID + Farcaster bulk) --------
def resolve_identities_batch():
    cutoff = int(time.time()) - 86400
    conn = db()
    rows = conn.execute(
        "SELECT address FROM deployers WHERE last_resolved < ? LIMIT 50",
        (cutoff,),
    ).fetchall()

    if not rows:
        conn.close()
        return

    addrs = [r["address"] for r in rows]
    log.info("Resolving identity for %d deployers", len(addrs))

    # Bulk Farcaster (single API call)
    fc = resolve_farcaster_bulk(addrs)

    now = int(time.time())
    for addr in addrs:
        sid = resolve_spaceid(addr)
        f = fc.get(addr, {})
        conn.execute(
            """UPDATE deployers
               SET spaceid=?, farcaster_username=?, farcaster_fid=?, farcaster_pfp=?, last_resolved=?
               WHERE address=?""",
            (sid, f.get("username"), f.get("fid"), f.get("pfp"), now, addr),
        )
        time.sleep(0.1)  # gentle on Space ID API
    conn.commit()
    conn.close()


# -------- Tx count refresh --------
def update_tx_counts():
    if not ETHERSCAN_API_KEY:
        return
    conn = db()
    cutoff = int(time.time()) - 7 * 86400
    stale = int(time.time()) - 3600
    rows = conn.execute(
        """SELECT address FROM contracts
           WHERE deployed_at > ? AND last_tx_count_update < ?
           ORDER BY deployed_at DESC LIMIT 30""",
        (cutoff, stale),
    ).fetchall()

    for row in rows:
        addr = row["address"]
        try:
            r = requests.get(
                ETHERSCAN_V2,
                params={
                    "chainid": BSC_CHAIN_ID,
                    "module": "account",
                    "action": "txlist",
                    "address": addr,
                    "page": 1,
                    "offset": 100,
                    "sort": "desc",
                    "apikey": ETHERSCAN_API_KEY,
                },
                timeout=10,
            )
            data = r.json()
            count = len(data.get("result", [])) if isinstance(data.get("result"), list) else 0
            conn.execute(
                "UPDATE contracts SET tx_count=?, last_tx_count_update=? WHERE address=?",
                (count, int(time.time()), addr),
            )
            time.sleep(0.25)
        except Exception as e:
            log.warning("tx count update failed for %s: %s", addr, e)
    conn.commit()
    conn.close()


# -------- AI classification batch --------
def ai_classify_batch():
    """
    Process up to 10 contracts per tick (every 2 min).
    Paces calls at 2.5s apart to stay under Cerebras 30 RPM hard limit.
    """
    conn = db()
    rows = conn.execute(
        """SELECT address, contract_type, contract_name, verified
           FROM contracts
           WHERE ai_classified_at = 0
           ORDER BY deployed_at DESC LIMIT 10"""
    ).fetchall()

    if not rows:
        conn.close()
        return

    classified = 0
    for row in rows:
        addr = row["address"]
        try:
            label, reason, score = classify_with_ai({
                "address": addr,
                "contract_type": row["contract_type"],
                "contract_name": row["contract_name"],
                "verified": bool(row["verified"]),
            })
            if label is None:
                # Transient error - leave ai_classified_at=0 so we retry
                continue
            conn.execute(
                """UPDATE contracts
                   SET ai_label=?, ai_reason=?, ai_score=?, ai_classified_at=?
                   WHERE address=?""",
                (label, reason, score, int(time.time()), addr),
            )
            classified += 1
            tag = "★" if label == "real" else " "
            log.info("  ai %s %s -> %s (%d) %s",
                     tag, addr[:10], label, score, reason[:40] if reason else "")
        except Exception as e:
            log.warning("ai classify exception for %s: %s", addr, e)
        # Pace: 2.5s between calls keeps us at 24 RPM safely
        time.sleep(2.5)
    conn.commit()
    conn.close()
    if classified:
        log.info("ai batch: %d classified", classified)


# -------- Scheduler --------
def main():
    init_db()
    sched = BlockingScheduler(timezone="UTC")
    sched.add_job(index_tick, "interval", seconds=POLL_INTERVAL_SEC,
                  max_instances=1, id="index")
    sched.add_job(update_verification_batch, "interval", minutes=5,
                  max_instances=1, id="verify")
    sched.add_job(resolve_identities_batch, "interval", minutes=10,
                  max_instances=1, id="identity")
    sched.add_job(update_tx_counts, "interval", minutes=15,
                  max_instances=1, id="txcount")
    sched.add_job(ai_classify_batch, "interval", minutes=2,
                  max_instances=1, id="ai")

    log.info("=== PulseBNB Indexer started (chainid=%d, AI=gpt-oss-120b) ===", BSC_CHAIN_ID)
    index_tick()
    sched.start()


if __name__ == "__main__":
    main()
